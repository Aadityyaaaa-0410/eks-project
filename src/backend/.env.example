# ── ConfigMap-like (non-sensitive) ─────────────────────────────
PORT=8080
APP_NAME=eks-demo-backend
APP_ENV=development
LOG_LEVEL=info
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# ── Secret-like (sensitive) ─────────────────────────────────────
# These will be injected by Kubernetes Secrets in production.
# Never commit real values to source control.
API_KEY=dev-placeholder-key
DB_PASSWORD=dev-placeholder-password
